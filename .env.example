###############################################################################
# EIAAW Recruiter — .env.example
#
# EIAAW Deploy Contract: only the Infisical bootstrap creds are raw values.
# Every other production secret is referenced as `secret://project/env/path/NAME`
# and resolved at boot by App\Providers\SecretsServiceProvider.
#
# This project resolves against the shared `eiaaw-all-projects` Infisical
# project (environment slug = `prod`). Secret names below match what already
# exists in that project (ANTHROPIC_API_KEY, RESEND_API, etc.).
###############################################################################

APP_NAME="EIAAW Recruiter"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kuala_Lumpur

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Infisical bootstrap — the ONLY raw secrets allowed in env
# -----------------------------------------------------------------------------
INFISICAL_RESOLVER_ENABLED=false
INFISICAL_SITE_URL=https://app.infisical.com
INFISICAL_APP_CLIENT_ID=
INFISICAL_APP_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=prod
INFISICAL_CACHE_TTL=300

# -----------------------------------------------------------------------------
# Database (PostgreSQL on Railway; sqlite for local dev)
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=recruiter
DB_USERNAME=postgres
DB_PASSWORD=secret://eiaaw-all-projects/prod/RECRUITER_DB_PASSWORD

# -----------------------------------------------------------------------------
# Cache, queue, session
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=secret://eiaaw-all-projects/prod/RECRUITER_REDIS_PASSWORD
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# AI providers (Infisical-resolved)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=secret://eiaaw-all-projects/prod/ANTHROPIC_API_KEY
ANTHROPIC_BASE_URL=https://api.anthropic.com
RECRUITER_MODEL_REASONING=claude-opus-4-7
RECRUITER_MODEL_DRAFT=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# Resend (outbound + Svix-signed inbound webhooks)
# Note: the shared Infisical project stores the API key as `RESEND_API`.
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="recruiter@notify.eiaawsolutions.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=secret://eiaaw-all-projects/prod/RESEND_API
RESEND_WEBHOOK_SIGNING_SECRET=secret://eiaaw-all-projects/prod/RESEND_WEBHOOK_SIGNING_SECRET

# -----------------------------------------------------------------------------
# Recruiter feature flags & limits
# -----------------------------------------------------------------------------
RECRUITER_REQUIRE_APPROVAL=true
RECRUITER_MAX_SOURCED_PER_JOB=50
RECRUITER_MIN_VERIFICATION_SOURCES=1
RECRUITER_DISCARD_LOW_CONFIDENCE=true
RECRUITER_WEBHOOK_RETRY_MAX=8
RECRUITER_WEBHOOK_SIGNATURE_HEADER=X-EIAAW-Signature
RECRUITER_API_RATE_LIMIT_PER_MIN=120

# -----------------------------------------------------------------------------
# Workforce handoff (EIAAW Workforce portal target)
# -----------------------------------------------------------------------------
WORKFORCE_BASE_URL=https://ep.eiaawsolutions.com
WORKFORCE_API_KEY=secret://eiaaw-all-projects/prod/WORKFORCE_API_KEY
WORKFORCE_HMAC_SECRET=secret://eiaaw-all-projects/prod/WORKFORCE_HMAC_SECRET

# -----------------------------------------------------------------------------
# Sanctum (UI auth + SPA)
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:8000,recruiter.eiaawsolutions.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://console.eiaawsolutions.com

# -----------------------------------------------------------------------------
# Calendar OAuth (Google Calendar + Microsoft Teams) — Infisical-resolved
# Note: these are the CALENDAR OAuth clients, distinct from GOOGLE_ADS_*.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=secret://eiaaw-all-projects/prod/GOOGLE_CALENDAR_CLIENT_SECRET
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=secret://eiaaw-all-projects/prod/MICROSOFT_CALENDAR_CLIENT_SECRET
