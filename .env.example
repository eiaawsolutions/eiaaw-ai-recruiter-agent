###############################################################################
# EIAAW Recruiter — .env.example
#
# EIAAW Deploy Contract: only the Infisical bootstrap creds are raw values.
# Every other production secret is referenced as `secret://project/env/path/NAME`
# and resolved at boot by App\Providers\SecretsServiceProvider.
###############################################################################

APP_NAME="EIAAW Recruiter"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kuala_Lumpur

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Infisical bootstrap — the ONLY raw secrets allowed in env
# -----------------------------------------------------------------------------
INFISICAL_RESOLVER_ENABLED=false
INFISICAL_SITE_URL=https://app.infisical.com
INFISICAL_APP_CLIENT_ID=
INFISICAL_APP_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=prod
INFISICAL_CACHE_TTL=300

# -----------------------------------------------------------------------------
# Database (PostgreSQL on Railway; sqlite for local dev)
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=recruiter
DB_USERNAME=postgres
DB_PASSWORD=secret://eiaaw-recruiter-prod/prod/DB_PASSWORD

# -----------------------------------------------------------------------------
# Cache, queue, session
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=secret://eiaaw-recruiter-prod/prod/REDIS_PASSWORD
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# AI providers (Infisical-resolved)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=secret://eiaaw-recruiter-prod/prod/ANTHROPIC_API_KEY
ANTHROPIC_BASE_URL=https://api.anthropic.com
RECRUITER_MODEL_REASONING=claude-opus-4-7
RECRUITER_MODEL_DRAFT=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# Mailgun outbound + inbound webhook
# -----------------------------------------------------------------------------
MAIL_MAILER=mailgun
MAIL_FROM_ADDRESS="recruiter@notify.eiaawsolutions.com"
MAIL_FROM_NAME="${APP_NAME}"
MAILGUN_DOMAIN=notify.eiaawsolutions.com
MAILGUN_SECRET=secret://eiaaw-recruiter-prod/prod/MAILGUN_SECRET
MAILGUN_WEBHOOK_SIGNING_KEY=secret://eiaaw-recruiter-prod/prod/MAILGUN_WEBHOOK_SIGNING_KEY
MAILGUN_ENDPOINT=api.mailgun.net

# -----------------------------------------------------------------------------
# Recruiter feature flags & limits
# -----------------------------------------------------------------------------
RECRUITER_REQUIRE_APPROVAL=true
RECRUITER_MAX_SOURCED_PER_JOB=50
RECRUITER_MIN_VERIFICATION_SOURCES=1
RECRUITER_DISCARD_LOW_CONFIDENCE=true
RECRUITER_WEBHOOK_RETRY_MAX=8
RECRUITER_WEBHOOK_SIGNATURE_HEADER=X-EIAAW-Signature
RECRUITER_API_RATE_LIMIT_PER_MIN=120

# -----------------------------------------------------------------------------
# Workforce handoff (EIAAW Workforce portal target)
# -----------------------------------------------------------------------------
WORKFORCE_BASE_URL=https://ep.eiaawsolutions.com
WORKFORCE_API_KEY=secret://eiaaw-recruiter-prod/prod/WORKFORCE_API_KEY
WORKFORCE_HMAC_SECRET=secret://eiaaw-recruiter-prod/prod/WORKFORCE_HMAC_SECRET

# -----------------------------------------------------------------------------
# Sanctum (UI auth + SPA)
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:8000,recruiter.eiaawsolutions.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://console.eiaawsolutions.com

# -----------------------------------------------------------------------------
# Calendar OAuth (Google + Microsoft) — Infisical-resolved
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=secret://eiaaw-recruiter-prod/prod/GOOGLE_CLIENT_SECRET
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=secret://eiaaw-recruiter-prod/prod/MICROSOFT_CLIENT_SECRET
